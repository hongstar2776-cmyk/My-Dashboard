                        </td>
                        <td class="px-6 py-2 text-right">
                            <input type="number" id="edit-qty-${item.id}" value="${item.qty}" min="1" class="w-16 border border-blue-400 rounded px-2 py-1 text-sm outline-none text-right bg-blue-50 focus:ring-1 focus:ring-blue-500">
                        </td>
