                            <td class="px-6 py-4 text-right text-green-700" id="totalArea4">0.000</td>
                            <td class="px-6 py-4 text-right text-orange-700" id="totalArea3">0.000</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

    </div>

