<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>강재 중량/면적 산출서</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 엑셀 다운로드를 위한 SheetJS 라이브러리 -->
