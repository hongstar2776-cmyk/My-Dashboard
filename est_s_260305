            // 환봉 (KS 표준)
            { type: '환봉', standard: 'D6', weight: 0.222, area4: 0.0188, area3: 0 },
            { type: '환봉', standard: 'D10', weight: 0.617, area4: 0.0314, area3: 0 },
            { type: '환봉', standard: 'D13', weight: 0.995, area4: 0.0398, area3: 0 },
            { type: '환봉', standard: 'D16', weight: 1.560, area4: 0.0498, area3: 0 },
            { type: '환봉', standard: 'D19', weight: 2.250, area4: 0.0598, area3: 0 },
            { type: '환봉', standard: 'D22', weight: 3.040, area4: 0.0698, area3: 0 },
            { type: '환봉', standard: 'D25', weight: 3.980, area4: 0.0798, area3: 0 },
            { type: '환봉', standard: 'D29', weight: 5.040, area4: 0.0900, area3: 0 },
            { type: '환봉', standard: 'D32', weight: 6.230, area4: 0.1000, area3: 0 }
        ];

        // 상태 변수
        let currentFocus = -1;
        let selectedSteelObj = null;
        let calculationList = [];

        const locInput = document.getElementById("locInput");
        const memberInput = document.getElementById("memberInput");
        const steelTypeSelect = document.getElementById("steelType");
        const standardInput = document.getElementById("standardSize");
        const lengthInput = document.getElementById("lengthInput");
        const qtyInput = document.getElementById("qtyInput");
        const autocompleteList = document.getElementById("autocomplete-list");
        const unitInfoDiv = document.getElementById("unitInfo");

        // --- 2. 자동완성 기능 ---
        
        standardInput.addEventListener("input", function(e) {
            let val = this.value;
            let typeVal = steelTypeSelect.value;
            closeAllLists();
            selectedSteelObj = null;
            unitInfoDiv.classList.add('hidden');
            
            if (!val) { return false; }
            currentFocus = -1;

            autocompleteList.classList.remove('hidden');
            autocompleteList.innerHTML = '';

            const matches = steelData.filter(item => 
                item.type === typeVal && item.standard.includes(val)
            );

            matches.forEach((item, index) => {
                let div = document.createElement("div");
                let matchIndex = item.standard.indexOf(val);
                let textBefore = item.standard.substring(0, matchIndex);
                let textMatch = item.standard.substring(matchIndex, matchIndex + val.length);
                let textAfter = item.standard.substring(matchIndex + val.length);
                
                div.innerHTML = `${textBefore}<strong class="text-blue-600">${textMatch}</strong>${textAfter}`;
                div.innerHTML += `<input type='hidden' value='${item.standard}'>`;
                
                div.addEventListener("click", function(e) {
                    standardInput.value = this.getElementsByTagName("input")[0].value;
                    selectItem(item);
                    closeAllLists();
                });
                autocompleteList.appendChild(div);
            });

            if (matches.length === 0) {
                let div = document.createElement("div");
                div.innerHTML = "<span class='text-gray-400'>검색 결과가 없습니다.</span>";
                autocompleteList.appendChild(div);
            }
        });

        steelTypeSelect.addEventListener("change", function() {
            standardInput.value = '';
            selectedSteelObj = null;
            unitInfoDiv.classList.add('hidden');
            closeAllLists();
        });

        function selectItem(item) {
            selectedSteelObj = item;
            unitInfoDiv.innerHTML = `
                <span class="font-semibold">[${item.type}] ${item.standard}</span> 
                선택됨 | 단중: <strong>${item.weight}</strong> kg/m, 면적(4면): <strong>${item.area4}</strong> m²/m, 면적(3면): <strong>${item.area3}</strong> m²/m
            `;
            unitInfoDiv.classList.remove('hidden');
            lengthInput.focus();
        }

        standardInput.addEventListener("keydown", function(e) {
            let x = document.getElementById("autocomplete-list");
            if (x) x = x.getElementsByTagName("div");
            if (!x || x.length === 0 || x[0].innerText === "검색 결과가 없습니다.") return;

            if (e.keyCode == 40) {
                currentFocus++;
                addActive(x);
                scrollToActive(x);
            } else if (e.keyCode == 38) {
                currentFocus--;
                addActive(x);
                scrollToActive(x);
            } else if (e.keyCode == 13) {
                e.preventDefault();
                if (currentFocus > -1) {
                    if (x) x[currentFocus].click();
                } else if (x.length > 0) {
                    x[0].click();
                }
            }
        });

        function addActive(x) {
            if (!x) return false;
            removeActive(x);
            if (currentFocus >= x.length) currentFocus = 0;
            if (currentFocus < 0) currentFocus = (x.length - 1);
            x[currentFocus].classList.add("autocomplete-active");
        }

        function removeActive(x) {
            for (let i = 0; i < x.length; i++) {
                x[i].classList.remove("autocomplete-active");
            }
        }

        function scrollToActive(x) {
            if (currentFocus > -1 && x[currentFocus]) {
                const list = document.getElementById("autocomplete-list");
                const activeEl = x[currentFocus];
                const offsetBottom = activeEl.offsetTop + activeEl.offsetHeight;
                if (offsetBottom > list.scrollTop + list.offsetHeight) {
                    list.scrollTop = offsetBottom - list.offsetHeight;
                } else if (activeEl.offsetTop < list.scrollTop) {
                    list.scrollTop = activeEl.offsetTop;
                }
            }
        }

        function closeAllLists(elmnt) {
            let x = document.getElementsByClassName("autocomplete-items");
            for (let i = 0; i < x.length; i++) {
                if (elmnt != x[i] && elmnt != standardInput) {
                    x[i].classList.add("hidden");
                }
            }
        }

        document.addEventListener("click", function (e) {
            closeAllLists(e.target);
        });

        // --- 3. 계산 및 리스트 추가 ---

        // 수량 창에서 엔터 누르면 리스트에 추가되게 이벤트 적용
        qtyInput.addEventListener("keydown", function(e) {
            if (e.keyCode === 13) {
                e.preventDefault();
                addToList();
            }
        });

        function addToList() {
            const locVal = locInput.value.trim();
            const memberVal = memberInput.value.trim();
            const typedStandard = standardInput.value.trim();
            const lengthVal = parseFloat(lengthInput.value);
            const qtyVal = parseInt(qtyInput.value) || 1; // 기본 수량 1
            const lossRateVal = parseFloat(document.getElementById("globalLossRate").value) || 0;
            const typeVal = steelTypeSelect.value;

            // 직접 타이핑하여 정확히 일치하는 값을 입력한 경우 자동 인식 처리
            if (!selectedSteelObj && typedStandard) {
                selectedSteelObj = steelData.find(item => item.type === typeVal && item.standard === typedStandard);
            }

            if (!selectedSteelObj) {
                alert("표준단면치수를 정확히 검색하여 선택하거나 정확하게 입력해주세요.");
                standardInput.focus();
                return;
            }
            if (isNaN(lengthVal) || lengthVal <= 0) {
                alert("올바른 길이(M)를 입력해주세요.");
                lengthInput.focus();
                return;
            }
            if (isNaN(qtyVal) || qtyVal <= 0) {
                alert("올바른 수량(EA)을 입력해주세요.");
                qtyInput.focus();
                return;
            }

            // 계산 (철골 물량산출 매커니즘 적용)
            const unitWeight = selectedSteelObj.weight;
            
            // 1. 총 중량 = 1m당 중량(단중) × 길이(m) × 수량(EA) × 할증률(로스)
            const calcWeight = lengthVal * qtyVal * unitWeight * (1 + lossRateVal / 100);
            
            // 2. 총 도장면적 = 1m당 면적 × 길이(m) × 수량(EA) (도장면적은 할증 미적용)
            const calcArea4 = selectedSteelObj.area4 * lengthVal * qtyVal;
            const calcArea3 = selectedSteelObj.area3 * lengthVal * qtyVal;

            const newItem = {
                id: Date.now(),
                location: locVal,
                member: memberVal,
                type: selectedSteelObj.type,
                standard: selectedSteelObj.standard,
                length: lengthVal,
                qty: qtyVal,
                unitWeight: unitWeight,
                lossRate: lossRateVal,
                weight: calcWeight,
                area4: calcArea4,
                area3: calcArea3
            };

            calculationList.push(newItem);
            renderTable();

            // 입력창 초기화 (위치, 부재명은 연속 입력을 위해 유지, 수량은 1로 리셋)
            standardInput.value = '';
            lengthInput.value = '';
            qtyInput.value = '1';
            selectedSteelObj = null;
            unitInfoDiv.classList.add('hidden');
            locInput.focus(); // 리스트 추가 후 위치 텍스트박스로 커서 자동 이동
        }

        // 일괄 로스율 변경 시 전체 데이터 재계산
        function updateGlobalLossRate() {
            const newRate = parseFloat(document.getElementById("globalLossRate").value) || 0;
            calculationList.forEach(item => {
                item.lossRate = newRate;
                // 단중 * 길이 * 수량 * (1+로스율)
                item.weight = item.length * item.qty * item.unitWeight * (1 + newRate / 100);
            });
            renderTable();
        }

        function deleteItem(id) {
            calculationList = calculationList.filter(item => item.id !== id);
            renderTable();
        }

        let editingId = null;

        function startEdit(id) {
            editingId = id;
            renderTable();
        }

        function cancelEdit() {
            editingId = null;
            renderTable();
        }

        function saveEdit(id) {
            const itemIndex = calculationList.findIndex(i => i.id === id);
            if (itemIndex === -1) return;
            const item = calculationList[itemIndex];

            // 수정된 값 가져오기
            const stdSelect = document.getElementById(`edit-std-${id}`).value;
            const lenInput = parseFloat(document.getElementById(`edit-len-${id}`).value);
            const qtyInput = parseInt(document.getElementById(`edit-qty-${id}`).value);

            // 입력값 검증 (오류 방지)
            if (isNaN(lenInput) || lenInput <= 0) {
                alert("올바른 길이(M)를 입력해주세요.");
                return;
            }
            if (isNaN(qtyInput) || qtyInput <= 0) {
                alert("올바른 수량(EA)을 입력해주세요.");
                return;
            }

            const matchedSteel = steelData.find(s => s.type === item.type && s.standard === stdSelect);
            if (!matchedSteel) {
                alert("해당 강종에 유효하지 않은 규격입니다."); // 콤보박스 선택이므로 거의 안일어남
                return;
            }

            const lossRateVal = parseFloat(document.getElementById("globalLossRate").value) || 0;

            // 데이터 업데이트 및 재계산
            item.standard = matchedSteel.standard;
            item.length = lenInput;
            item.qty = qtyInput;
            item.unitWeight = matchedSteel.weight;
            item.weight = item.length * item.qty * item.unitWeight * (1 + lossRateVal / 100);
            item.area4 = matchedSteel.area4 * item.length * item.qty;
            item.area3 = matchedSteel.area3 * item.length * item.qty;

            editingId = null; // 수정 모드 종료
            renderTable();
        }

        function renderTable() {
            const tbody = document.getElementById("listBody");
            const emptyRow = document.getElementById("emptyRow");
            
            tbody.innerHTML = '';
            let tWeight = 0, tArea4 = 0, tArea3 = 0;

            if (calculationList.length === 0) {
                tbody.innerHTML = `<tr><td colspan="13" class="px-6 py-8 text-center text-gray-500">데이터를 입력하여 리스트를 추가해주세요.</td></tr>`;
                updateTotals(0, 0, 0);
                return;
            }

            calculationList.forEach((item, index) => {
                tWeight += item.weight;
                tArea4 += item.area4;
                tArea3 += item.area3;

                const isEditing = editingId === item.id;
                const tr = document.createElement('tr');
                tr.className = "hover:bg-gray-50 transition-colors";

                if (isEditing) {
                    // 편집 모드 렌더링 (안전한 드롭다운 적용)
                    const availableSteels = steelData.filter(s => s.type === item.type);
                    const optionsHtml = availableSteels.map(s => 
