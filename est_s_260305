                        <td class="px-6 py-3 text-right text-gray-400">${item.lossRate}%</td>
                        <td class="px-6 py-3 text-right font-bold text-gray-400">${item.weight.toLocaleString('ko-KR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                        <td class="px-6 py-3 text-right text-gray-400">${item.area4.toLocaleString('ko-KR', {minimumFractionDigits: 3, maximumFractionDigits: 3})}</td>
                        <td class="px-6 py-3 text-right text-gray-400">${item.area3.toLocaleString('ko-KR', {minimumFractionDigits: 3, maximumFractionDigits: 3})}</td>
                        <td class="px-6 py-2 text-center">
                            <div class="flex justify-center gap-1">
                                <button onclick="saveEdit(${item.id})" class="bg-green-100 text-green-700 hover:bg-green-200 px-2 py-1 rounded text-xs font-bold transition-colors shadow-sm">저장</button>
                                <button onclick="cancelEdit()" class="bg-gray-200 text-gray-700 hover:bg-gray-300 px-2 py-1 rounded text-xs transition-colors shadow-sm">취소</button>
                            </div>
                        </td>
                    `;
                } else {
                    // 일반 모드 렌더링
                    tr.innerHTML = `
                        <td class="px-6 py-3 border-r border-gray-100">${index + 1}</td>
                        <td class="px-6 py-3 text-gray-700">${item.location}</td>
                        <td class="px-6 py-3 text-gray-700">${item.member}</td>
                        <td class="px-6 py-3 font-medium text-gray-900">${item.type}</td>
                        <td class="px-6 py-3 text-blue-600 font-mono">${item.standard}</td>
                        <td class="px-6 py-3 text-right bg-gray-50 font-medium">${item.length.toLocaleString('ko-KR', {minimumFractionDigits: 1, maximumFractionDigits: 3})}</td>
                        <td class="px-6 py-3 text-right bg-blue-50 font-semibold">${item.qty}</td>
                        <td class="px-6 py-3 text-right text-gray-600">${item.unitWeight.toLocaleString('ko-KR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                        <td class="px-6 py-3 text-right text-gray-600">${item.lossRate}%</td>
                        <td class="px-6 py-3 text-right font-bold text-gray-900">${item.weight.toLocaleString('ko-KR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                        <td class="px-6 py-3 text-right text-gray-600">${item.area4.toLocaleString('ko-KR', {minimumFractionDigits: 3, maximumFractionDigits: 3})}</td>
                        <td class="px-6 py-3 text-right text-gray-600">${item.area3.toLocaleString('ko-KR', {minimumFractionDigits: 3, maximumFractionDigits: 3})}</td>
                        <td class="px-6 py-3 text-center">
                            <div class="flex justify-center gap-2">
                                <button onclick="startEdit(${item.id})" class="text-blue-500 hover:text-blue-700 hover:bg-blue-50 p-1.5 rounded transition-colors" title="수정">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                                    </svg>
                                </button>
                                <button onclick="deleteItem(${item.id})" class="text-red-500 hover:text-red-700 hover:bg-red-50 p-1.5 rounded transition-colors" title="삭제">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                            </div>
                        </td>
                    `;
                }
                tbody.appendChild(tr);
            });

            updateTotals(tWeight, tArea4, tArea3);
        }

        function updateTotals(w, a4, a3) {
            document.getElementById("totalWeight").innerText = w.toLocaleString('ko-KR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById("totalArea4").innerText = a4.toLocaleString('ko-KR', {minimumFractionDigits: 3, maximumFractionDigits: 3});
            document.getElementById("totalArea3").innerText = a3.toLocaleString('ko-KR', {minimumFractionDigits: 3, maximumFractionDigits: 3});
        }

        // --- 4. 엑셀 내보내기 ---
        function exportToExcel() {
            if (calculationList.length === 0) {
                alert("내보낼 데이터가 없습니다.");
                return;
            }

            const projectName = document.getElementById("projectName").value || "공사명 미지정";

            let excelData = [];
            
            excelData.push(["강재 중량 및 면적 산출서"]);
            excelData.push(["공사명:", projectName]);
            excelData.push([]); 
            
            // 헤더에 수량(EA) 추가
            excelData.push(["No.", "위치", "부재명", "항목", "표준단면치수", "길이(M)", "수량(EA)", "단위중량(kg/m)", "로스율(%)", "중량(KG)", "단위면적 4면(M²)", "단위면적 3면(M²)"]);
            
            let tw=0, ta4=0, ta3=0;
            calculationList.forEach((item, index) => {
                let excelRow = index + 5; 
                
                // 중량에 수식 적용: F열(길이) * G열(수량) * H열(단위중량) * (1 + I열(로스율)/100)
                let weightFormula = { 
                    t: 'n', 
                    v: item.weight, 
                    f: `F${excelRow}*G${excelRow}*H${excelRow}*(1+I${excelRow}/100)` 
                };

                excelData.push([
                    index + 1,
                    item.location,
                    item.member,
                    item.type,
                    item.standard,
                    item.length,
                    item.qty,
                    item.unitWeight,
                    item.lossRate,
                    weightFormula, // 수식 셀
                    item.area4,
                    item.area3
                ]);
                tw += item.weight; ta4 += item.area4; ta3 += item.area3;
            });

            let totalRow = calculationList.length + 6;
            excelData.push(["", "", "", "", "", "", "", "", "", "", "", ""]);
            excelData.push([
                "총 합계", "", "", "", "", "", "", "", "", 
                { t: 'n', v: tw, f: `SUM(J5:J${totalRow-2})` }, // J열 (중량) 합계
                { t: 'n', v: ta4, f: `SUM(K5:K${totalRow-2})` }, // K열 (4면) 합계
                { t: 'n', v: ta3, f: `SUM(L5:L${totalRow-2})` }  // L열 (3면) 합계
            ]);

            var wb = XLSX.utils.book_new();
            var ws = XLSX.utils.aoa_to_sheet(excelData);

            // 열 너비 자동 조절 
            var wscols = [
                {wch:5}, {wch:10}, {wch:10}, {wch:15}, {wch:25}, {wch:10}, {wch:8}, {wch:15}, {wch:10}, {wch:15}, {wch:15}, {wch:15}
            ];
            ws['!cols'] = wscols;

            XLSX.utils.book_append_sheet(wb, ws, "강재산출서");
            
            const dateStr = new Date().toISOString().slice(0, 10).replace(/-/g, "");
            XLSX.writeFile(wb, `강재산출서_${dateStr}.xlsx`);
        }

    </script>
</body>
