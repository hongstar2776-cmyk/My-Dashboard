        </div>

        <!-- 헤더 -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div class="flex-1 w-full">
                <h1 class="text-2xl font-bold text-gray-900">강재 중량 및 면적 산출서</h1>
                <div class="mt-3 flex flex-col md:flex-row items-start md:items-center gap-4">
                    <div class="flex items-center gap-3 w-full md:w-auto">
                        <label class="font-medium text-gray-700 whitespace-nowrap">공사명</label>
                        <input type="text" id="projectName" placeholder="공사명을 입력하세요" class="w-full md:w-64 border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none bg-gray-50">
                    </div>
                    <div class="flex items-center gap-3 w-full md:w-auto">
                        <label class="font-medium text-gray-700 whitespace-nowrap">일괄 로스율 (%)</label>
                        <input type="number" id="globalLossRate" value="3" step="0.1" min="0" onchange="updateGlobalLossRate()"
                            class="w-24 border border-gray-300 rounded-lg p-2 focus:ring-2 focus:ring-blue-500 outline-none bg-gray-50" title="변경 시 전체 리스트에 즉시 반영됩니다.">
                    </div>
                </div>
            </div>
            <button onclick="exportToExcel()" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-sm whitespace-nowrap">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
                엑셀로 내보내기
            </button>
        </div>

        <!-- 입력부 -->
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-200">
            <h2 class="text-lg font-semibold mb-4 border-b pb-2">항목 입력</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-7 gap-4 items-end">
                
                <!-- 0. 위치 입력 -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">위치 (예: 1F)</label>
                    <input type="text" id="locInput" placeholder="위치 입력" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                </div>

                <!-- 0. 부재명 입력 -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">부재명 (예: 1SC1)</label>
                    <input type="text" id="memberInput" placeholder="부재명 입력" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                </div>

                <!-- 1. 항목 (콤보박스) -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">항목 (강종)</label>
                    <select id="steelType" class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none bg-gray-50">
                        <option value="H-BEAM">H-BEAM</option>
                        <option value="C형강">C형강</option>
                        <option value="I형강">I형강</option>
                        <option value="ㄷ형강">ㄷ형강</option>
                        <option value="ㄱ형강">ㄱ형강</option>
                        <option value="환봉">환봉</option>
                    </select>
                </div>

                <!-- 2. 표준단면치수 (자동완성 텍스트박스) -->
                <div class="relative">
                    <label class="block text-sm font-medium text-gray-700 mb-1">표준단면치수 검색</label>
                    <input type="text" id="standardSize" placeholder="예: 100 입력 후 방향키" autocomplete="off"
                        class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                    <div id="autocomplete-list" class="autocomplete-items hidden"></div>
                </div>

                <!-- 3. 길이 입력 -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">길이 (M)</label>
                    <input type="number" id="lengthInput" placeholder="길이 입력" step="0.001" min="0"
                        class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                </div>

                <!-- 3.5 수량 입력 -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">수량 (EA)</label>
                    <input type="number" id="qtyInput" placeholder="수량 입력 (Enter)" value="1" min="1"
                        class="w-full border border-gray-300 rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
                </div>

                <!-- 4. 추가 버튼 -->
                <div>
                    <button id="addBtn" onclick="addToList()" class="w-full bg-blue-600 hover:bg-blue-700 text-white p-2.5 rounded-lg font-medium transition-colors shadow-sm whitespace-nowrap">
                        리스트에 추가
                    </button>
                </div>
            </div>
            
            <!-- 선택된 항목의 단위 정보 표시 영역 -->
            <div id="unitInfo" class="mt-4 p-3 bg-blue-50 text-blue-800 text-sm rounded-lg border border-blue-100 hidden">
                <!-- JS에서 채워짐 -->
            </div>
        </div>

        <!-- 리스트 및 합계 영역 -->
        <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-200">
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left whitespace-nowrap" id="resultTable">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-50 border-b">
                        <tr>
                            <th class="px-6 py-3">No.</th>
                            <th class="px-6 py-3">위치</th>
                            <th class="px-6 py-3">부재명</th>
                            <th class="px-6 py-3">항목</th>
                            <th class="px-6 py-3">표준단면치수</th>
                            <th class="px-6 py-3 text-right">길이 (M)</th>
                            <th class="px-6 py-3 text-right">수량 (EA)</th>
                            <th class="px-6 py-3 text-right">단위중량 (kg/m)</th>
                            <th class="px-6 py-3 text-right">로스율 (%)</th>
                            <th class="px-6 py-3 text-right">중량 (KG)</th>
                            <th class="px-6 py-3 text-right">단위면적 4면 (M²)</th>
                            <th class="px-6 py-3 text-right">단위면적 3면 (M²)</th>
                            <th class="px-6 py-3 text-center">관리</th>
